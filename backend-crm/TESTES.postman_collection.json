{
  "info": {
    "name": "Marcenaria CRM API",
    "_postman_id": "12345678-abcd-efgh-ijkl-987654321",
    "description": "Coleção de testes da API Marcenaria CRM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8080" },
    { "key": "TOKEN_ADMIN", "value": "" },
    { "key": "TOKEN_USER", "value": "" },
    { "key": "CLIENTE_ID", "value": "" },
    { "key": "PEDIDO_ID", "value": "" },
    { "key": "ESTOQUE_ID", "value": "" },
    { "key": "MOVIMENTACAO_ID", "value": "" }
